{
  "name": "assignments-weekly",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/)(?!.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/remind", "schedule": "0 4 * * 0-4" },
    { "path": "/api/remind", "schedule": "0 5 * * 0-4" }
  ]
}
